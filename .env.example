APP_NAME="Dental AI Chatbot"
ENVIRONMENT=development
API_PREFIX=/api
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:8000,https://demo.wtechx.tech,https://api.wtechx.tech

DATABASE_URL=sqlite:///./dental_ai.db

JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALLOW_ADMIN_REGISTRATION=false
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_FULL_NAME="Dental AI Admin"

QDRANT_URL=
QDRANT_LOCAL_PATH=qdrant_storage
QDRANT_API_KEY=
QDRANT_COLLECTION=dental_docs
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
RETRIEVAL_TOP_K=5

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=512
OLLAMA_TIMEOUT_SECONDS=180

UPLOAD_DIR=uploaded_docs
MAX_UPLOAD_MB=200
CHUNK_SIZE=1000
CHUNK_OVERLAP=180
EMBEDDING_BATCH_SIZE=64
VECTOR_UPSERT_BATCH_SIZE=128
OCR_DPI=250
OCR_LANGUAGE=eng
OCR_CONFIG=--psm 6
TESSERACT_CMD=
POPPLER_PATH=

DATASET_LLM_PROVIDER=openai
DATASET_GENERATION_STALE_MINUTES=20
OPENAI_MODEL_FALLBACKS=gpt-4.1-mini,gpt-4o-mini,gpt-3.5-turbo
WEB_SEARCH_PROVIDER=tavily
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TRUSTED_DOMAINS=who.int,cdc.gov,nih.gov,ncbi.nlm.nih.gov,nhs.uk,ada.org,nice.org.uk,fda.gov
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=your-google-custom-search-engine-id
GOOGLE_SEARCH_API_KEY=your-google-custom-search-api-key
