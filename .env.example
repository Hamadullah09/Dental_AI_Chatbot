APP_NAME="Dental AI Chatbot"
ENVIRONMENT=development
API_PREFIX=/api
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:8000,https://demo.wtechx.tech,https://api.wtechx.tech

DATABASE_URL=postgresql+psycopg://dental:change-this-postgres-password@postgres:5432/dental_ai
POSTGRES_PASSWORD=change-this-postgres-password
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOW_ADMIN_REGISTRATION=false
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_FULL_NAME="Dental AI Admin"

REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=20
REDIS_CACHE_TTL_SECONDS=3600
REDIS_SESSION_TTL_SECONDS=86400
REDIS_RATE_LIMIT_TTL_SECONDS=60

QDRANT_URL=http://qdrant:6333
QDRANT_LOCAL_PATH=
QDRANT_API_KEY=
QDRANT_TIMEOUT_SECONDS=120
QDRANT_COLLECTION=dental_docs_clean
QDRANT_VISUAL_COLLECTION=dental_visuals
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
RETRIEVAL_TOP_K=5
RETRIEVAL_CANDIDATE_MULTIPLIER=4
RETRIEVAL_MIN_CANDIDATES=20
RETRIEVAL_MAX_RESULTS=5
RETRIEVAL_MIN_RESULTS=3
ENABLE_KEYWORD_SEARCH=true
KEYWORD_SEARCH_SCAN_LIMIT=500
RAG_MODE=simple
RETRIEVAL_MIN_RELEVANCE_SCORE=1.1
ALLOW_GENERAL_FALLBACK=true
ENABLE_MEMORY=true
ENABLE_QUERY_REWRITING=false
ENABLE_ADJACENT_CHUNK_EXPANSION=true
ADJACENT_CHUNK_WINDOW=1
ENABLE_HYDE=false
ENABLE_SELF_CHECK=false
SELF_CHECK_UNGROUNDED_THRESHOLD=0.25
ENABLE_BGE_RERANKER=false
BGE_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
BGE_RERANKER_MAX_CHUNKS=40
BGE_RERANKER_MAX_CHARS=1600
MULTI_QUERY_MAX_VARIANTS=4
MULTI_QUERY_CONFIDENCE_THRESHOLD=1.35
HYDE_CONFIDENCE_THRESHOLD=1.35
HYDE_MAX_PASSAGE_CHARS=900
CORRECTIVE_CONFIDENCE_THRESHOLD=1.35
MEMORY_CONTEXT_MAX_CHARS=320
MEMORY_CONTEXT_MESSAGES=4
CONVERSATION_HISTORY_LIMIT=8
RERANK_TRUST_HIGH_BOOST=0.25
RERANK_TRUST_MEDIUM_BOOST=0.1
RERANK_TRUST_LOW_BOOST=-0.25
RERANK_APPROVED_BOOST=0.2
RERANK_QUALITY_BASELINE=0.6
RERANK_QUALITY_MULTIPLIER=0.5
RERANK_KEYWORD_WEIGHT=0.35
RERANK_LEXICAL_WEIGHT=0.2
BM25_K1=1.5
BM25_B=0.75
CONTEXT_COMPRESSION_MAX_CHARS=1000

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_FALLBACKS=gpt-4.1-mini,gpt-4o-mini,gpt-3.5-turbo
OPENAI_TEMPERATURE=0.2
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b
OLLAMA_VISION_MODEL=qwen2.5vl:7b
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=512
OLLAMA_TOP_P=0.8
OLLAMA_TIMEOUT_SECONDS=300
OLLAMA_VISION_TIMEOUT_SECONDS=180
OLLAMA_KEEP_ALIVE=0s
OLLAMA_CONNECT_TIMEOUT=5.0
OLLAMA_WRITE_TIMEOUT=10.0
OLLAMA_POOL_TIMEOUT=5.0
OLLAMA_VISION_CONNECT_TIMEOUT=5.0
OLLAMA_VISION_WRITE_TIMEOUT=20.0
OLLAMA_VISION_POOL_TIMEOUT=5.0
OLLAMA_HEALTH_CHECK_TIMEOUT=1.0
API_PROXY_URL=http://api:8000
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_BACKEND_HEALTH_TIMEOUT_MS=1500
NEXT_PUBLIC_CHAT_GENERATION_TIMEOUT_MS=300000

DATASET_LLM_PROVIDER=openai
DATASET_GENERATION_STALE_MINUTES=20
DATASET_GENERATION_TEMPERATURE=0.2
DATASET_GENERATION_CHUNK_TEXT_MAX_CHARS=3500
DATASET_OUTPUT_DIR=.

UPLOAD_DIR=uploaded_docs
EXTRACTED_VISUALS_DIR=uploads/extracted_visuals
MAX_UPLOAD_MB=200
INGESTION_TIMEOUT_SECONDS=7200
CHUNK_SIZE=1000
CHUNK_OVERLAP=180
CHUNK_MIN_WORDS=5
CHUNK_MIN_QUALITY_SCORE=0.6
EMBEDDING_BATCH_SIZE=64
VECTOR_UPSERT_BATCH_SIZE=128
VECTOR_UPSERT_MAX_RETRIES=3
VECTOR_UPSERT_RETRY_DELAY_MULTIPLIER=0.5
DB_COMMIT_MAX_RETRIES=8
DB_COMMIT_RETRY_DELAY=0.25
ENABLE_MULTIMODAL_RAG=true
VISUAL_PAGE_SNAPSHOT_ZOOM=1.6
VISUAL_MIN_RELEVANCE_SCORE=0.95
VISUAL_CANDIDATE_MULTIPLIER=4
VISUAL_MIN_CANDIDATES=12
VISUAL_CHUNK_LINKED_MULTIPLIER=3
VISUAL_CHUNK_LINKED_MIN=8
VISUAL_WANTS_ANSWER_THRESHOLD_REDUCTION=0.75
VISUAL_SAME_PAGE_BOOST=0.12
VISUAL_MAX_CHUNK_LINKED_ROWS=250
VISUAL_MAX_TO_ANALYZE=2
VISUAL_OBSERVATION_MAX_WORDS=80
VISUAL_OBSERVATION_MAX_CHARS=700
VISUAL_CAPTION_MAX_CHARS=320
VISUAL_NEARBY_TEXT_MAX_CHARS=1200
VISUAL_MAX_TABLES_PER_PAGE=5
VISUAL_TABLE_IMAGE_DPI=150
VISUAL_QUALITY_BASELINE=0.45
VISUAL_CAPTION_BOOST=0.3
VISUAL_NONSNAPSHOT_BOOST=0.15
VISUAL_NEARBY_TEXT_WORD_THRESHOLD=35
VISUAL_NEARBY_TEXT_BOOST=0.1
VISUAL_RANK_WANTS_ANSWER_BOOST=0.5
VISUAL_RANK_SAME_PAGE_BOOST=0.45
VISUAL_RANK_RELATED_CHUNK_BOOST=0.55
VISUAL_RANK_CAPTION_BOOST=0.25
VISUAL_RANK_QUALITY_BASELINE=0.45
VISUAL_RANK_QUALITY_MULTIPLIER=0.45
VISUAL_RANK_LEXICAL_WEIGHT=0.18
OCR_DPI=250
OCR_LANGUAGE=eng
OCR_CONFIG=--psm 6
OCR_MIN_LINE_LENGTH=4
OCR_GARBAGE_PENALTY=0.45
TESSERACT_CMD=
POPPLER_PATH=

WEB_SEARCH_PROVIDER=tavily
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT_SECONDS=20
WEB_SEARCH_MAX_RESULT_CHARS=1800
WEB_SEARCH_MAX_RESULTS_CAP=10
WEB_SEARCH_TRUSTED_DOMAINS=who.int,cdc.gov,nih.gov,ncbi.nlm.nih.gov,nhs.uk,ada.org,nice.org.uk,fda.gov
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=your-google-custom-search-engine-id
GOOGLE_SEARCH_API_KEY=your-google-custom-search-api-key

RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_CHAT_PER_MINUTE=20
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_UPLOAD_PER_MINUTE=5

STREAMING_ENABLED=true
STREAMING_CHUNK_SIZE=10
STREAMING_TIMEOUT_SECONDS=300

LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=
LOG_REQUEST_ID=true

PROMETHEUS_ENABLED=true
PROMETHEUS_PATH=/metrics

WORKER_CONCURRENCY=4
WORKER_MAX_RETRIES=3
WORKER_RETRY_DELAY_SECONDS=5
