APP_NAME="Dental AI Chatbot"
ENVIRONMENT=development
API_PREFIX=/api
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:8000

DATABASE_URL=postgresql+psycopg://dental:change-this-postgres-password@postgres:5432/dental_ai
POSTGRES_PASSWORD=change-this-postgres-password
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

JWT_SECRET_KEY=dental-ai-secret-key-change-in-production-32chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOW_ADMIN_REGISTRATION=false
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_FULL_NAME="Dental AI Admin"

REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=20
REDIS_CACHE_TTL_SECONDS=3600
REDIS_SESSION_TTL_SECONDS=86400
REDIS_RATE_LIMIT_TTL_SECONDS=60

QDRANT_URL=http://qdrant:6333
QDRANT_LOCAL_PATH=
QDRANT_API_KEY=
QDRANT_COLLECTION=dental_chunks
KEYWORD_SEARCH_SCAN_LIMIT=500
ENABLE_QUERY_REWRITING=true
ENABLE_KEYWORD_SEARCH=true
ENABLE_HYDE=false
ENABLE_BGE_RERANKER=false
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_RELEVANCE_SCORE=0.3

# --- LLM Provider: ollama (office PC with RTX 5060Ti) ---
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_TEXT_MODEL=qwen2.5:7b
OLLAMA_VISION_MODEL=qwen2.5vl:7b
OLLAMA_DEFAULT_MODEL=qwen2.5vl:7b
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=256
OLLAMA_TOP_P=0.8
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_VISION_TIMEOUT_SECONDS=90
OLLAMA_KEEP_ALIVE=5m
OLLAMA_HEALTH_CHECK_TIMEOUT=5.0

# --- Uncomment below to use OpenAI instead of Ollama ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

UPLOAD_DIR=/app/uploaded_docs
EXTRACTED_VISUALS_DIR=/app/uploads/extracted_visuals
MAX_UPLOAD_SIZE_MB=200
CHUNK_SIZE=800
CHUNK_OVERLAP=200
EMBEDDING_BATCH_SIZE=64
VECTOR_UPSERT_BATCH_SIZE=128
INGESTION_TIMEOUT_SECONDS=600

OCR_DPI=250
OCR_LANGUAGE=eng
OCR_CONFIG=--psm 6
TESSERACT_CMD=
POPPLER_PATH=

RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_CHAT_PER_MINUTE=20
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_UPLOAD_PER_MINUTE=5

STREAMING_ENABLED=true
STREAMING_CHUNK_SIZE=10
STREAMING_TIMEOUT_SECONDS=300

LOG_LEVEL=INFO
LOG_FORMAT=json
PROMETHEUS_ENABLED=true
PROMETHEUS_PATH=/metrics

WORKER_CONCURRENCY=4
WORKER_MAX_RETRIES=3
WORKER_RETRY_DELAY_SECONDS=5

MEDICAL_DISCLAIMER="Dental AI is for education and clinical decision support only. It does not replace diagnosis, treatment planning, or emergency care from a licensed dentist."
